#!/usr/bin/env hy

(setv per-unit              570
      registration          450
      international-service 400
      document-management   63)

(setv units (int (input "Number of units: ")))

(print "Total fee(does not include application fee, housing, living expenses, travel/visa expenses, \
or Course Materials and Services Fee(s)): $"
       (+ 
        (* units per-unit)
        registration
        international-service
        document-management))

