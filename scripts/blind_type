#!/usr/bin/env hy

(import gtts io os time pyglet random multiprocessing)
(require hyrule *)
(print (os.path.realpath __file__))

(let [proxy "http://127.0.0.1:7891"] ;; In China you need this
  (assoc os.environ "http_proxy" proxy
                    "HTTP_PROXY" proxy
                    "https_proxy" proxy
                    "HTTPS_PROXY" proxy))

(assoc pyglet.options "audio" (, "pulse"))

(defn play [sound]
  (let [player (sound.play)]
    (while player.playing
      (pyglet.app.platform-event-loop.dispatch-posted-events)
      (pyglet.clock.tick))))
  
(defn speak [words [lang "en"]]
  (with [f (io.BytesIO)]
    (.write_to_fp (gtts.gTTS :text words :lang lang) f)
    (f.seek 0)
    (setv player (play (pyglet.media.load "_.mp3" :file f)))))

(with [f (open (+ (os.path.realpath __file__) "data/text/google-10000-english-no-swears.txt") :mode "r")]
  (let [word-list (.split (f.read) "\n")
        correct (pyglet.media.load "data/audio/correct.mp3")
        incorrect (pyglet.media.load "data/audio/incorrect.mp3")
        pool (multiprocessing.Pool)]
    (while True
      (let [cur (random.choice word-list)]
        (speak cur)
        (play (if (= cur (input (+ cur ": ")))
               correct
               incorrect))))))
          
